# ============================================
# EVIS AI — Variáveis de Ambiente
# ============================================
#
# INSTRUÇÕES:
# 1. Copie este arquivo para .env
# 2. Preencha os valores reais (remova as aspas para produção)
# 3. NUNCA commite o arquivo .env (está no .gitignore)
#
# ============================================

# ──────────────────────────────────────────
# SERVIDOR BACKEND
# ──────────────────────────────────────────

# Porta do servidor Node.js/Express
PORT=3001

# Ambiente de execução (development | production)
NODE_ENV=development

# ──────────────────────────────────────────
# SUPABASE (Banco de Dados)
# ──────────────────────────────────────────

# URL do projeto Supabase
VITE_SUPABASE_URL="your_supabase_project_url_here"

# Chave pública (anon key) do Supabase
VITE_SUPABASE_ANON_KEY="your_supabase_anon_key_here"

# Chave de serviço (service_role key) — APENAS BACKEND
# ⚠️ CUIDADO: Esta chave bypassa RLS. Não exponha no frontend!
SUPABASE_SERVICE_ROLE_KEY=""

# ──────────────────────────────────────────
# IA / LLMs
# ──────────────────────────────────────────

# Google Gemini API Key (usado pelo orquestrador e frontend legado)
# Obtenha em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="your_gemini_api_key_here"
VITE_GEMINI_API_KEY="your_gemini_api_key_here"

# Anthropic API Key (Claude) — Opcional
VITE_ANTHROPIC_API_KEY=""

# OpenRouter API Key (para Minimax) — Opcional
VITE_OPENROUTER_API_KEY=""

# Ollama URL (se rodar localmente) — Opcional
VITE_OLLAMA_URL="http://localhost:11434/api/generate"

# ──────────────────────────────────────────
# IMGBB (Upload de Fotos)
# ──────────────────────────────────────────

# ImgBB API Key para armazenamento de imagens
# Obtenha em: https://api.imgbb.com/
VITE_IMGBB_API_KEY=""

# ──────────────────────────────────────────
# N8N (Automação - Opcional)
# ──────────────────────────────────────────

# URL do webhook n8n para processamento de áudio via WhatsApp
N8N_WEBHOOK_URL=""

# ──────────────────────────────────────────
# APLICAÇÃO
# ──────────────────────────────────────────

# URL onde a aplicação está hospedada
APP_URL="http://localhost:3000/"

# ID da obra padrão (pode ser configurado via UI)
VITE_OBRA_ID=""

# ──────────────────────────────────────────
# ORÇAMENTISTA IA — FLAGS DE PROTEÇÃO (LAB)
# ──────────────────────────────────────────

# Habilita análise IA real (Gemini) no Orçamentista.
# Padrão: desligado. Apenas LAB/DEV local.
EVIS_ORCAMENTISTA_ENABLE_AI_ANALYZE=

# Permite uso do Supabase principal em modo dev.
# Padrão: desligado. Apenas LAB/DEV local.
EVIS_ALLOW_MAIN_SUPABASE_DEV_MODE=

# ============================================
# NOTAS DE SEGURANÇA
# ============================================
#
# ✅ Usar VITE_ prefix para variáveis do frontend (Vite as expõe)
# ❌ NUNCA use VITE_ para secrets do backend (service_role, etc)
# ✅ .env está no .gitignore — confirme antes de commitar
# ✅ Para produção, use variáveis de ambiente do servidor/Vercel
#
# ============================================
